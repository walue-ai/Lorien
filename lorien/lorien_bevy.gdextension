[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.1"

[libraries]
linux.debug.x86_64 = "res://rust/target/release/liblorien_bevy.so"
linux.release.x86_64 = "res://rust/target/release/liblorien_bevy.so"
windows.debug.x86_64 = "res://rust/target/debug/lorien_bevy.dll"
windows.release.x86_64 = "res://rust/target/release/lorien_bevy.dll"
macos.debug = "res://rust/target/debug/liblorien_bevy.dylib"
macos.release = "res://rust/target/release/liblorien_bevy.dylib"
macos.debug.arm64 = "res://rust/target/debug/liblorien_bevy.dylib"
macos.release.arm64 = "res://rust/target/release/liblorien_bevy.dylib"
